#include <ext/pb_ds/assoc_container.hpp>
#include <ext/pb_ds/tree_policy.hpp>
using namespace __gnu_pbds;
template<class T>
using ordered_multiset = tree<T, null_type, less_equal<T>, rb_tree_tag, tree_order_statistics_node_update>;

///find_by_order(k) = kth element
///The order_of_key(k) = number of element strictly less than k


void solve()
{
    ll n,q;
    cin>>n>>q;
    set<ll>st;
    st.insert(0);
    st.insert(n);
    ordered_multiset<ll>ln;
    ln.insert(n);
    while(q--)
    {
        char c;cin>>c;
        ll a;cin>>a;
        if(c=='C')
        {
            if(a>n)continue;
            if(a==n)
            {
                ln.insert(0);
            }
            auto it1 = st.upper_bound(a);
            auto it2 = prev(it1);
            ll koto = *it1 - *it2;
            auto it = ln.find_by_order(ln.order_of_key(koto));
            ln.erase(it);
            ll l1 = *it1 - a;
            ll l2 =  a - *it2;
            //cout<<l1<<" "<<l2<<endl;
            ln.insert(l1);
            ln.insert(l2);
            st.insert(a);
        }
        else
        {
            if(a>=st.size())
            {
                a = st.size()-1;
            }
            auto val = ln.find_by_order(a-1);
            // cout<<*val<<endl;
        }
    }
    for(auto i:ln)cout<<i<<" ";
}
int32_t main()
{
    edm();
    int t = 1;
    cin>>t;
    for(int i=1; i<=t; i++)
    {
        cout<<"Case "<<i<<": ";
        cout<<endl;
        solve();
    }
}
